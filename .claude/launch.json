{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Kolmena API Server",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@kolmena/server", "dev"],
      "port": 4080
    },
    {
      "name": "Kolmena Mobile (Expo)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--port", "8081"],
      "port": 8081
    },
    {
      "name": "Drizzle Studio",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@kolmena/server", "db:studio"],
      "port": 4983
    }
  ]
}
